# ==========================================
# LLM 配置（必填）
# ==========================================

# API Key（支持 OpenAI / DeepSeek / 通义千问等任意兼容接口）
LLM_API_KEY=sk-your-key-here

# API Base URL（默认 OpenAI，可改为 DeepSeek / 阿里云 DashScope 等）
LLM_BASE_URL=https://api.openai.com/v1

# 模型名称（推荐 gpt-4o-mini 或 deepseek-chat）
LLM_MODEL=gpt-4o-mini

# ==========================================
# Redis 配置（可选，不配置则使用内存缓存）
# ==========================================
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=3600

# ==========================================
# 服务配置
# ==========================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ==========================================
# 阿里云 FC 部署（如部署到 FC 则设为 true）
# ==========================================
FC_ENABLED=false
